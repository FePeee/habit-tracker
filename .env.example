# Copy this file to .env and fill in real values.
# After changing keys, recreate containers:
#   docker compose up -d --force-recreate bot backend

# Telegram Bot Token (get from @BotFather)
BOT_TOKEN=your_telegram_bot_token_here

# OpenRouter API Key (for AI reports, advice, suggestions)
# Get it from https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# JWT secret for web auth (change for production!)
# SECRET_KEY=some-random-secret-string

# Optional OpenRouter headers
# OPENROUTER_HTTP_REFERER=https://localhost
# OPENROUTER_APP_TITLE=Habit Tracker
